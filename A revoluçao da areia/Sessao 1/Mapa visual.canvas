			"y":-160,
			"width":480,
			"height":380
		},
		{"id":"31ec3fc170d7fcac","type":"file","file":"A revoluçao da areia/Sessao 1/O Revolucionario.md","x":-3020,"y":-120,"width":480,"height":376},
		{"id":"293219639e9b2d10","type":"text","text":"Ajudar o revolucinario a sobreviver","x":-2418,"y":-225,"width":250,"height":60,"color":"5"},
		{"id":"c337be670275c39a","type":"text","text":"Pegar a carta e deixar ele","x":-2418,"y":295,"width":250,"height":60,"color":"5"},
		{"id":"951966cb1f98ae1b","type":"text","text":"Entregar o revolucionario","x":-2418,"y":36,"width":250,"height":60,"color":"5"},
		{"id":"1b064b52ab9ae718","type":"text","text":"Novos oficiais chamam o grupo para ajudalos como civis","x":-2092,"y":14,"width":272,"height":105},
		{
			"id":"407ecd308d984a30",
			"type":"text",
			"text":"Isso abre espaço para traiçao mais profunda do movimento",
