views:
  - type: table
    name: Tabela
    filters:
      and:
        - file.inFolder("Sistema/Magias")
        - file.hasProperty("custo")
    groupBy:
      property: Círculo
      direction: ASC
    order:
      - file.name
      - custo
      - Tipo
      - Duração
      - Componentes
      - alcance
    sort:
      - property: custo
        direction: ASC
