views:
  - type: table
    name: Tabela
    filters:
      and:
        - file.inFolder("Sistema/Magias")
        - file.hasProperty("custo")
    groupBy:
      property: file.folder
      direction: ASC
    order:
      - file.name
      - custo
      - Tipo
      - Duração
      - Componentes
      - alcance
      - file.folder
    sort: []
